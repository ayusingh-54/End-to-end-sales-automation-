# =============================================================================
# Learn with Leaders — Future Doctors Fellowship pipeline
# Placeholder values only. Real secrets live in host secret managers.
# Copy to .env.local for local dev. NEVER commit .env*.
# =============================================================================

# ---- Node / runtime ---------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---- Supabase (DB + Auth + Storage) -----------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only; never expose to client
SUPABASE_DB_URL=                  # postgresql://... for migrations / direct SQL

# ---- Admin app (Next.js) ----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_ALLOWED_EMAILS=             # comma-separated allowlist for magic-link login
SESSION_SECRET=                   # 32+ random bytes, base64

# ---- n8n (orchestration) ----------------------------------------------------
N8N_WEBHOOK_URL=                  # base URL for webhook triggers from admin app
N8N_WEBHOOK_SECRET=               # HMAC shared secret; admin signs, n8n verifies
N8N_BASIC_AUTH_USER=              # for the n8n editor UI
N8N_BASIC_AUTH_PASSWORD=

# ---- Apollo (contact enrichment) --------------------------------------------
APOLLO_API_KEY=
APOLLO_DAILY_QUOTA=               # numeric; rate limiter reads from config row anyway

# ---- LinkedIn verification agent (existing LWL service) ---------------------
LINKEDIN_AGENT_URL=
LINKEDIN_AGENT_API_KEY=

# ---- Scraper providers ------------------------------------------------------
FIRECRAWL_API_KEY=                # fallback when Playwright is blocked
SCRAPINGBEE_API_KEY=              # secondary fallback (optional)
SCRAPER_USER_AGENT=LWL-LeadBot/1.0 (+https://learnwithleaders.com/bot)

# ---- Email validation -------------------------------------------------------
ZEROBOUNCE_API_KEY=

# ---- Email providers --------------------------------------------------------
INSTANTLY_API_KEY=                # cold outreach
RESEND_API_KEY=                   # transactional (receipts, confirmations)
EMAIL_FROM_ADDRESS=               # e.g. fdf@outreach.learnwithleaders.com
EMAIL_FROM_NAME=Learn with Leaders
EMAIL_REPLY_TO=

# ---- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=                # sk_test_... locally, sk_live_... in prod
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=            # whsec_...

# ---- Object storage (Cloudflare R2) -----------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lwl-resources
R2_PUBLIC_BASE_URL=               # for signed-URL generation

# ---- Zoom (attendance pull) -------------------------------------------------
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                # build-time, source maps upload
BETTER_STACK_SOURCE_TOKEN=        # log shipping
