    "test": "node --test --import tsx \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@lwl/db": "workspace:*",
    "@lwl/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "robots-parser": "^3.0.1",
    "undici": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
